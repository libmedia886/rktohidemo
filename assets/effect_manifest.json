{
  "screen": {
    "width": 1080,
    "height": 1920,
    "orientation": "portrait",
    "interface": "MIPI/DSI"
  },
  "camera": {
    "device": "/dev/video-camera0",
    "format": "NV12",
    "width": 640,
    "height": 640,
    "role": "live visible-light source"
  },
  "modules": [
    {"name": "VI", "source": "camera", "effect": "live visible-light input"},
    {"name": "VPSS", "source": "camera", "effect": "multi-output crop/scale fanout"},
    {"name": "VO", "source": "composited frame", "effect": "portrait dashboard display"},
    {"name": "WBC", "source": "camera + DRM writeback", "effect": "Scaled VI reference beside scaled VO_WBC capture mixed back to VO"},
    {"name": "RGA", "source": "camera", "effect": "crop / rotate / mosaic / fast blit"},
    {"name": "RESIZE_RGA", "source": "camera", "effect": "hardware resize tiles"},
    {"name": "CSC_RGA", "source": "camera", "effect": "RGA color conversion path"},
    {"name": "CSC_CL", "source": "camera", "effect": "OpenCL color conversion path"},
    {"name": "OSD", "source": "camera", "effect": "HUD boxes / scan line / status overlay"},
    {"name": "CLAHE", "source": "camera", "effect": "local contrast enhancement"},
    {"name": "RETINEX", "source": "camera video", "effect": "original video and Retinex output comparison"},
    {"name": "CAP_DEHAZE", "source": "camera", "effect": "CAP dehaze comparison"},
    {"name": "DCP_FAST_DEHAZE", "source": "camera", "effect": "fast dark-channel dehaze comparison"},
    {"name": "THERMAL", "source": "/userdata/rktohi/demo/thermal/1.png, /userdata/rktohi/demo/thermal/2.png", "effect": "pseudo thermal color map from rktohi demo images"},
    {"name": "CONV_CL", "source": "camera", "effect": "edge / sharpen / blur tiles"},
    {"name": "TRANSFORM", "source": "camera", "effect": "same-source RAW / undistort / rotate-zoom / perspective LUT warp"},
    {"name": "BLEND_PYR", "source": "camera + loop mask", "effect": "soft wipe fusion"},
    {"name": "EDOF_CL", "source": "loop image pair", "effect": "near/far focus fusion"},
    {"name": "EXPOSURE_FUSION_CL", "source": "synthetic dark/bright pair", "effect": "HDR-style exposure fusion"},
    {"name": "MCF_FUSION_CL", "source": "assets/loop/mcf_fusion/*/color.jpg + mono.jpg", "effect": "OpenCL color/mono detail fusion with reference fallback"},
    {"name": "DUALVIEW", "source": "generated RGB888 red/blue pair from demo_dualview_processing.c", "effect": "side-by-side and line-by-line dual-output comparison"},
    {"name": "STEREO_3D", "source": "camera", "effect": "VPSS raw plus 90-degree rotated branch merged by STEREO_3D without color tint"},
    {"name": "VMIX", "source": "all tile streams", "effect": "Vulkan compositor path"},
    {"name": "VMIX_RGA", "source": "all tile streams", "effect": "RGA compositor path"},
    {"name": "PANO", "source": "assets/loop/pano/sample2/camera_0.jpg..camera_5.jpg", "effect": "six-image panorama stitch using PTO"},
    {"name": "AVM", "source": "assets/loop/avm_inputs/*.jpg", "effect": "2D surround view"},
    {"name": "SVM3D", "source": "assets/svm3d/svm_3d_assets.json", "effect": "3D surround-view sweep"},
    {"name": "NPU", "source": "assets/loop/npu/bus_640x640.h264", "effect": "VDEC + RGA + YOLOv5 detection boxes"},
    {"name": "VENC", "source": "composited frame", "effect": "H.264 stream encode"},
    {"name": "VDEC", "source": "RTSP loopback", "effect": "network return preview"},
    {"name": "RTSP_SEND", "source": "VENC", "effect": "network stream out"},
    {"name": "RTSP_RECV", "source": "rtsp://127.0.0.1:8554/rktohi_all", "effect": "network loopback in"},
    {"name": "PIC_IO", "source": "loop assets", "effect": "image-sequence source and recorder"}
  ]
}
